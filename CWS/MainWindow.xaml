<Window x:Class="CWS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CWS 控制中心" Height="450" Width="750"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="MainBlue" Color="#00BCF2"/>
        <SolidColorBrush x:Key="PanelBg" Color="#99000000"/>

        <Style x:Key="CustomSliderThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="{StaticResource MainBlue}" Width="12" Height="12" Stroke="White" StrokeThickness="1.5"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" Background="#66FFFFFF" CornerRadius="2" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource CustomSliderThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="Transparent" BorderBrush="{StaticResource MainBlue}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="BorderThickness" Value="4,0,0,0"/>
                                <Setter TargetName="bg" Property="Background" Value="#5500BCF2"/>
                                <Setter Property="Foreground" Value="{StaticResource MainBlue}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="BorderBrush" Value="#6600BCF2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Background="{TemplateBinding Background}" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                CornerRadius="5"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#44FFFFFF"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#00BCF2"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Grid Margin="{TemplateBinding Padding}" IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" 
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                  VerticalAlignment="Center"/>
                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="White" 
                                      StrokeThickness="1.5" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </Grid>

                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" 
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border x:Name="dropDownBorder" Background="#F205101E" BorderBrush="#00BCF2" 
                                        BorderThickness="1" CornerRadius="5" 
                                        MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="itemBorder" Background="Transparent" CornerRadius="3" Margin="2,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#00BCF2"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#3300BCF2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#AA1A3A5A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource MainBlue}"/>
                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="{StaticResource MainBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCtrlBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="WindowOnLoadStoryboard">
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorderScale" Storyboard.TargetProperty="ScaleX" From="0.95" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorderScale" Storyboard.TargetProperty="ScaleY" From="0.95" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="#FA05101E" CornerRadius="15" BorderBrush="#66FFFFFF" BorderThickness="1.2" Opacity="0">
        <Border.RenderTransform>
            <ScaleTransform x:Name="MainBorderScale" CenterX="375" CenterY="225"/>
        </Border.RenderTransform>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource PanelBg}" CornerRadius="15,0,0,15">
                <StackPanel Margin="0,40,0,0">
                    <TextBlock Text="CWS ASSISTANT" Foreground="{StaticResource MainBlue}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    <RadioButton Content="{DynamicResource Lang_Nav_General}" IsChecked="True" Style="{StaticResource NavButtonStyle}" Click="Nav_General_Click"/>
                    <RadioButton Content="{DynamicResource Lang_Nav_PPT}" Style="{StaticResource NavButtonStyle}" Click="Nav_PPTOpt_Click"/>
                    <RadioButton Content="{DynamicResource Lang_Nav_About}" Style="{StaticResource NavButtonStyle}" Click="Nav_About_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="30,25,30,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Hidden">
                    <StackPanel>
                        <StackPanel x:Name="PageGeneral" Visibility="Visible">
                            <TextBlock Text="{DynamicResource Lang_Nav_General}" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

                            <Border Background="#44FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#33FFFFFF" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Lang_Card_BgTitle}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    <DockPanel Margin="0,12,0,5">
                                        <TextBlock Text="{DynamicResource Lang_Card_BgOpacity}" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtOpacityPercent" Text="100%" Foreground="{StaticResource MainBlue}" FontSize="12" FontWeight="Bold" DockPanel.Dock="Right" Width="40" TextAlignment="Right"/>
                                        <Slider x:Name="sldBgOpacity" Minimum="0" Maximum="1" Value="1" Margin="10,0" ValueChanged="sldBgOpacity_ValueChanged"/>
                                    </DockPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Button x:Name="btnBrowseBackground" Content="{DynamicResource Lang_Btn_Browse}" Width="100" Margin="0,0,10,0" Click="btnBrowseBackground_Click"/>
                                        <Button x:Name="btnRemoveBackground" Content="{DynamicResource Lang_Btn_Clear}" Width="100" Click="btnRemoveBackground_Click" Background="#441A3A5A"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="#44FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#33FFFFFF" BorderThickness="1">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Lang_Card_StartupTitle}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{DynamicResource Lang_Card_StartupDesc}" Foreground="#AAA" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="chkRunAtStartup" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="chkRunAtStartup_Checked" Unchecked="chkRunAtStartup_Unchecked"/>
                                    </DockPanel>
                                    <Separator Background="#22FFFFFF" Margin="0,5"/>
                                    <DockPanel Margin="0,10,0,0">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource Lang_Card_MonitorTitle}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{DynamicResource Lang_Card_MonitorDesc}" Foreground="#AAA" FontSize="11"/>
                                        </StackPanel>
                                        <CheckBox x:Name="chkMonitorPPT" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="ChkMonitorPPT_Checked" Unchecked="ChkMonitorPPT_Unchecked"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{DynamicResource Lang_Label_QuickFix}" Foreground="#88FFFFFF" FontSize="12" Margin="5,10,0,5"/>
                            <WrapPanel>
                                <Button x:Name="btnCleanWPS" Content="{DynamicResource Lang_Btn_CleanWPS}" Click="btnCleanWPS_Click" Width="130" Margin="0,0,8,8"/>
                                <Button x:Name="btnRestartPPTService" Content="{DynamicResource Lang_Btn_RestartPPT}" Click="btnRestartPPTService_Click" Width="130" Margin="0,0,8,8"/>
                                <Button x:Name="btnSwitchToFloating" Content="{DynamicResource Lang_Btn_Floating}" Click="btnSwitchToFloating_Click" Width="130" Margin="0,0,8,8"/>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel x:Name="PagePPTOpt" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource Lang_Nav_PPT}" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

                            <Border Background="#44FFFFFF" CornerRadius="8" Padding="15" BorderBrush="#33FFFFFF" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Lang_Card_AssocTitle}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="{DynamicResource Lang_Card_AssocDesc}" Foreground="#AAA" FontSize="11" Margin="0,4,0,15"/>

                                    <WrapPanel>
                                        <Button Content="{DynamicResource Lang_Btn_SetPPT}" Click="btnSetPPT_Click" Width="140" Margin="0,0,10,10"/>
                                        <Button Content="{DynamicResource Lang_Btn_SetWPS}" Click="btnSetWPS_Click" Width="140" Margin="0,0,10,10"/>

                                        <Button x:Name="btnRestartExplorer" 
                        Content="{DynamicResource Lang_Btn_RestartExplorer}" 
                        Click="btnRestartExplorer_Click" 
                        Width="180" Margin="0,0,10,10"
                        Background="#4400BCF2" BorderBrush="#6600BCF2"/>

                                        <Button x:Name="btnCleanIconCache" 
                        Content="{DynamicResource Lang_Btn_CleanCache}" 
                        Click="btnCleanIconCache_Click" 
                        Width="140" Margin="0,0,10,10"
                        Background="#44FF4500" BorderBrush="#88FF4500"/>
                                    </WrapPanel>

                                    <TextBlock Text="{DynamicResource Lang_Tip_IconFix}" Foreground="{StaticResource MainBlue}" FontSize="10" Opacity="0.7" Margin="2,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="PageAbout" Visibility="Collapsed">
                            <TextBlock Text="{DynamicResource Lang_Nav_About}" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
                            <Border Background="#44FFFFFF" CornerRadius="8" Padding="20" BorderBrush="#33FFFFFF" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock x:Name="txtVersionDisplay" Text="CWS v0.4.0" Foreground="{StaticResource MainBlue}" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="{DynamicResource Lang_About_Author}" Foreground="#DDD" Margin="0,10,0,0"/>
                                    <TextBlock Text="{DynamicResource Lang_About_Desc}" Foreground="#AAA" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                    <Separator Background="#22FFFFFF" Margin="0,20"/>
                                    <TextBlock Text="{DynamicResource Lang_About_License}" FontSize="12" Foreground="White" Opacity="0.6"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <DockPanel Grid.Row="1" Margin="0,15,0,0">
                    <TextBlock x:Name="txtStatus" Text="{DynamicResource Lang_Status_Default}" Foreground="{StaticResource MainBlue}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="🌐" Foreground="#66FFFFFF" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                        <ComboBox x:Name="comboLang" Width="110" Style="{StaticResource ModernComboBoxStyle}" SelectionChanged="comboLang_SelectionChanged">
                            <ComboBoxItem Content="简体中文" Tag="zh-CN" IsSelected="True"/>
                            <ComboBoxItem Content="繁体中文(HK)" Tag="zh-HK"/>
                            <ComboBoxItem Content="繁体中文(TW)" Tag="zh-TW"/>
                            <ComboBoxItem Content="English" Tag="en-US"/>
                            <ComboBoxItem Content="Music Factory" Tag="te-Yi"/>
                            <ComboBoxItem Content="Pseudo" Tag="pc-Ba"/>
                        </ComboBox>
                    </StackPanel>
                </DockPanel>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-20,-15,0">
                    <Button Style="{StaticResource WindowCtrlBtn}" Click="btnMinimize_Click">
                        <TextBlock Text="—" FontSize="10" Foreground="White"/>
                    </Button>
                    <Button Style="{StaticResource WindowCtrlBtn}" Click="OnClose_Click">
                        <TextBlock Text="✕" FontSize="14" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>