<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- WinUI-like palette -->
    <Color x:Key="WinUIAccentColor">#FF0078D4</Color>
    <SolidColorBrush x:Key="WinUIAccentBrush" Color="{StaticResource WinUIAccentColor}" />
    <SolidColorBrush x:Key="WinUIAccentBrushLight" Color="#FF2B88D8" />
    <SolidColorBrush x:Key="WinUIWindowBackground" Color="#001F3F" />
    <SolidColorBrush x:Key="WinUIForeground" Color="White" />
    <SolidColorBrush x:Key="WinUIControlBackground" Color="#0F2433" />

    <!-- Global font similar to WinUI -->
    <FontFamily x:Key="WinUIFont">Segoe UI</FontFamily>

    <!-- Window base style -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WinUIWindowBackground}" />
        <Setter Property="Foreground" Value="{StaticResource WinUIForeground}" />
        <Setter Property="FontFamily" Value="{StaticResource WinUIFont}" />
    </Style>

    <!-- Button style: rounded, accent-filled -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource WinUIAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="{StaticResource WinUIFont}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0" RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource WinUIAccentBrushLight}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox basic style: keep label separate, but also style box visuals -->
    <Style TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource WinUIFont}" />
        <Setter Property="Foreground" Value="{StaticResource WinUIForeground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="16" Height="16">
                            <Border x:Name="Box" Width="16" Height="16" CornerRadius="2" BorderBrush="{StaticResource WinUIAccentBrush}" BorderThickness="1" Background="Transparent" />
                            <!-- Check glyph (hidden by default) -->
                            <Path x:Name="CheckMark" Data="M2,8 L6,12 L14,4" Stroke="White" StrokeThickness="2" StrokeEndLineCap="Round" StrokeStartLineCap="Round" Visibility="Collapsed" />
                        </Grid>
                        <ContentPresenter Content="{TemplateBinding Content}" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource WinUIAccentBrush}" />
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource WinUIAccentBrushLight}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Box" Property="Opacity" Value="0.5" />
                            <Setter TargetName="CheckMark" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBlock defaults -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource WinUIForeground}" />
        <Setter Property="FontFamily" Value="{StaticResource WinUIFont}" />
    </Style>

</ResourceDictionary>
